{
  "name": "gestion-stocks-pharma-frontend",
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "REACT_APP_API_URL": "https://pharma-backend.onrender.com/api"
  },
  "build": {
    "env": {
      "CI": "false"
    }
  }
}